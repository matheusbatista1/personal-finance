# Supabase — required. Validated by src/lib/env.ts at runtime.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Site — required. Base URL for OAuth callbacks and transactional email links.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Resend — optional. Transactional email sender is a graceful no-op when unset.
RESEND_API_KEY=

# Upstash Redis — optional. Rate limiters return null when unset (no-op).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Google OAuth credentials — interpolated into supabase/config.toml only.
# NOT read by the Next.js app directly (env.ts does not validate these).
# Set them here for `supabase start` to provision the Google provider locally.
ID_CLIENT_OAUTH=
SECRET_KEY_OAUTH=
