# Supabase (filled in the next delivery — not used yet)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Site (used for OAuth callbacks, transactional email links)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Resend (optional — transactional email; sender is no-op when unset)
RESEND_API_KEY=

# Upstash (optional — rate limit; graceful no-op when unset)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Google OAuth (used by Supabase Auth Google provider)
ID_CLIENT_OAUTH=
SECRET_KEY_OAUTH=
